          <h3 class="font-semibold text-charcoal text-lg mb-2">Text Chat Agents</h3>
          <p class="text-sm text-slate-custom leading-relaxed">
            Clean chat interface for text-based interviews. Customisable avatars, same structured data output, no audio required.
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="group bg-white rounded-2xl p-6 border border-oasis-100/60 hover:border-oasis-300/60 transition-all hover:shadow-lg hover:shadow-oasis-100/50 animate-fade-in-up">
          <div class="w-12 h-12 rounded-xl bg-oasis-100 text-oasis-500 flex items-center justify-center mb-4 group-hover:bg-oasis-500 group-hover:text-white transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
            </svg>
          </div>
          <h3 class="font-semibold text-charcoal text-lg mb-2">Structured Protocols</h3>
          <p class="text-sm text-slate-custom leading-relaxed">
            Semi-structured interview guides with preset questions, follow-up probes, and configurable transitions. Upload protocols via CSV or JSON.
          </p>
        </div>

        <!-- Feature 4 -->
        <div class="group bg-white rounded-2xl p-6 border border-oasis-100/60 hover:border-oasis-300/60 transition-all hover:shadow-lg hover:shadow-oasis-100/50 animate-fade-in-up">
          <div class="w-12 h-12 rounded-xl bg-sand-300 text-sand-700 flex items-center justify-center mb-4 group-hover:bg-sand-500 group-hover:text-white transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
