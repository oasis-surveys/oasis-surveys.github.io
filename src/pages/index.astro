---
import Base from '../layouts/Base.astro';
---

<Base activeNav="home">

  <!-- ════════════════════════════════════════════════════════════
       HERO
       ════════════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden">
    <!-- Subtle gradient bg -->
    <div class="absolute inset-0 bg-gradient-to-br from-oasis-50 via-off-white to-sand-100 -z-10"></div>
    <!-- Decorative circles -->
    <div class="absolute top-20 -left-32 w-96 h-96 bg-oasis-200/30 rounded-full blur-3xl -z-10"></div>
    <div class="absolute bottom-10 right-0 w-80 h-80 bg-sand-300/20 rounded-full blur-3xl -z-10"></div>

    <div class="max-w-6xl mx-auto px-6 py-24 md:py-32">
      <div class="flex flex-col items-center text-center">
        <!-- Logo -->
        <img
          src="/oasis-logo.png"
          alt="OASIS"
          class="w-40 h-40 md:w-52 md:h-52 mb-8 animate-float drop-shadow-lg"
        />

        <!-- Badge -->
        <div class="inline-flex items-center gap-2 bg-oasis-100/60 text-oasis-600 text-xs font-semibold px-3 py-1.5 rounded-full mb-6 animate-fade-in">
          <span class="w-2 h-2 bg-oasis-400 rounded-full animate-pulse"></span>
          Open Source · Self-Hosted · Research-First
