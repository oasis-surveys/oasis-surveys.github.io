  <!-- Terminal animation script -->
  <script>
    // Terminal typing data for each terminal
    const terminalData: Record<string, string[]> = {
      '1': [
        'git clone https://github.com/oasis-surveys/oasis-platform.git',
        '', '', // outputs (no typing)
        'cp .env.example .env',
        'nano .env'
      ],
      '2': [
        'docker compose up -d',
        '', '', '', '', '', '' // outputs only
      ],
      '3': [] // no typing, all outputs
    };

    // Cascade base delays: terminal 1 → 0ms, terminal 2 → 5.5s, terminal 3 → 10.5s
    const cascadeDelay: Record<string, number> = {
      '1': 500,
      '2': 6000,
      '3': 11000
    };

    function animateTerminal(terminal: HTMLElement) {
      const id = terminal.getAttribute('data-terminal') || '';
      const lines = terminal.querySelectorAll('.term-line');
      const typingTexts = terminalData[id] || [];
      const baseDelay = cascadeDelay[id] || 0;
      let typingIdx = 0;

      lines.forEach((line, i) => {
        const el = line as HTMLElement;
        const type = el.getAttribute('data-type');
        const delay = baseDelay + parseInt(el.getAttribute('data-delay') || '0');

        setTimeout(() => {
          el.classList.remove('hidden');
          el.style.opacity = '0';
          el.style.transform = 'translateY(4px)';
          requestAnimationFrame(() => {
            el.style.transition = 'opacity 300ms ease, transform 300ms ease';
            el.style.opacity = '1';
            el.style.transform = 'translateY(0)';
          });

          if (type === 'typing') {
            const textSpan = el.querySelector('.term-text') as HTMLElement;
            const cursor = el.querySelector('.term-cursor') as HTMLElement;
            const fullText = typingTexts[typingIdx] || '';
            typingIdx++;
            let charIdx = 0;

            if (cursor) cursor.style.display = 'inline';

            const typeInterval = setInterval(() => {
              if (charIdx <= fullText.length) {
                if (textSpan) textSpan.textContent = fullText.slice(0, charIdx);
                charIdx++;
              } else {
                clearInterval(typeInterval);
                if (cursor) cursor.style.display = 'none';
              }
            }, 35);
          }
        }, delay);
      });
    }

    // Use IntersectionObserver — observe the SECTION so all three start together
    const termSection = document.getElementById('how-it-works');
    let terminalsStarted = false;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && !terminalsStarted) {
          terminalsStarted = true;
          document.querySelectorAll('.oasis-terminal').forEach(t => {
            animateTerminal(t as HTMLElement);
          });
        }
      });
    }, { threshold: 0.2 });

    if (termSection) observer.observe(termSection);
  </script>

  <style>
    .term-cursor {
      color: #a3e635;
      animation: blink 1s step-end infinite;
    }
    @keyframes blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }
  </style>

