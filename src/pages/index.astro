        <!-- Headline -->
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold leading-tight tracking-tight text-charcoal animate-fade-in-up max-w-4xl">
          Open Agentic Survey<br/>
          <span class="text-oasis-500">Interview System</span>
        </h1>

        <!-- Subtitle -->
        <p class="mt-6 text-lg md:text-xl text-slate-custom max-w-2xl leading-relaxed animate-fade-in-up" style="animation-delay: 150ms;">
          Deploy AI-powered conversational interviewers in minutes.
          Voice agents, text chat, structured protocols. Your infrastructure, your data, your models.
        </p>

        <!-- CTAs -->
        <div class="mt-10 flex flex-col sm:flex-row items-center gap-4 animate-fade-in-up" style="animation-delay: 300ms;">
          <a
            href="/docs"
