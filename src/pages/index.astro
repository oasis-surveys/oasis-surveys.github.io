---
import Base from '../layouts/Base.astro';
---

<Base activeNav="home">

  <!-- ════════════════════════════════════════════════════════════
       HERO
       ════════════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden">
    <!-- Subtle gradient bg -->
    <div class="absolute inset-0 bg-gradient-to-br from-oasis-50 via-off-white to-sand-100 -z-10"></div>
    <!-- Decorative circles -->
    <div class="absolute top-20 -left-32 w-96 h-96 bg-oasis-200/30 rounded-full blur-3xl -z-10"></div>
    <div class="absolute bottom-10 right-0 w-80 h-80 bg-sand-300/20 rounded-full blur-3xl -z-10"></div>

    <div class="max-w-6xl mx-auto px-6 py-24 md:py-32">
      <div class="flex flex-col items-center text-center">
        <!-- Logo -->
        <img
          src="/oasis-logo.png"
          alt="OASIS"
          class="w-40 h-40 md:w-52 md:h-52 mb-8 animate-float drop-shadow-lg"
        />

        <!-- Badge -->
        <div class="inline-flex items-center gap-2 bg-oasis-100/60 text-oasis-600 text-xs font-semibold px-3 py-1.5 rounded-full mb-6 animate-fade-in">
          <span class="w-2 h-2 bg-oasis-400 rounded-full animate-pulse"></span>
          Open Source · Self-Hosted · Research-First
        </div>

        <!-- Headline -->
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold leading-tight tracking-tight text-charcoal animate-fade-in-up max-w-4xl">
          Open Agentic Survey<br/>
          <span class="text-oasis-500">Interview System</span>
        </h1>

        <!-- Subtitle -->
        <p class="mt-6 text-lg md:text-xl text-slate-custom max-w-2xl leading-relaxed animate-fade-in-up" style="animation-delay: 150ms;">
          Deploy AI-powered conversational interviewers in minutes.
          Voice agents, text chat, structured protocols. Your infrastructure, your data, your models.
        </p>

        <!-- CTAs -->
        <div class="mt-10 flex flex-col sm:flex-row items-center gap-4 animate-fade-in-up" style="animation-delay: 300ms;">
          <a
            href="/docs"
            class="inline-flex items-center gap-2 bg-oasis-500 hover:bg-oasis-600 text-white font-semibold px-7 py-3.5 rounded-xl transition-all shadow-lg shadow-oasis-500/20 hover:shadow-oasis-500/30 hover:-translate-y-0.5"
          >
            Get Started
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a
            href="https://github.com/oasis-surveys/oasis-platform"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-charcoal hover:bg-charcoal/90 text-white font-semibold px-7 py-3.5 rounded-xl transition-all hover:-translate-y-0.5"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            View on GitHub
          </a>
        </div>

        <!-- Open Science tagline -->
        <div class="mt-14 flex flex-wrap items-center justify-center gap-3 animate-fade-in-up" style="animation-delay: 450ms;">
          <span class="inline-flex items-center gap-1.5 bg-oasis-50 text-oasis-600 text-xs font-semibold px-3.5 py-1.5 rounded-full border border-oasis-200/50">
            🔬 Built for Researchers
          </span>
          <span class="inline-flex items-center gap-1.5 bg-oasis-50 text-oasis-600 text-xs font-semibold px-3.5 py-1.5 rounded-full border border-oasis-200/50">
            🔓 Open Science
          </span>
          <span class="inline-flex items-center gap-1.5 bg-oasis-50 text-oasis-600 text-xs font-semibold px-3.5 py-1.5 rounded-full border border-oasis-200/50">
            🏠 Self-Hosted
          </span>
          <span class="inline-flex items-center gap-1.5 bg-sand-100 text-sand-700 text-xs font-semibold px-3.5 py-1.5 rounded-full border border-sand-200/50">
            🆓 Free &amp; Non-Commercial
          </span>
        </div>
      </div>
    </div>
  </section>


  <!-- ════════════════════════════════════════════════════════════
       EARLY DAYS NOTICE (auto-hides after June 2026)
       ════════════════════════════════════════════════════════════ -->
  <div id="launch-notice" class="hidden">
    <div class="max-w-4xl mx-auto px-6 py-4">
      <div class="relative bg-oasis-50/80 border border-oasis-200/60 rounded-xl px-5 py-4 flex items-start gap-3 animate-fade-in">
        <div class="flex-shrink-0 mt-0.5">
          <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-oasis-500 text-white text-xs font-bold">!</span>
        </div>
        <div class="flex-1">
          <p class="text-sm text-charcoal font-semibold mb-1">OASIS is a young project</p>
          <p class="text-sm text-slate-custom leading-relaxed">
            OASIS launched publicly in March 2026. While the platform has been tested extensively across different virtual machines,
            operating systems, and deployment setups, it is still a young project. You may encounter rough edges, especially in less
            common configurations. If something breaks, please
            <a href="https://github.com/oasis-surveys/oasis-platform/issues/new" class="text-oasis-500 hover:underline font-medium">open an issue</a>.
          </p>
        </div>
        <button onclick="this.closest('#launch-notice').remove()" class="flex-shrink-0 text-slate-custom/60 hover:text-charcoal transition-colors p-1" aria-label="Dismiss">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <script>
    // Show the launch notice only until June 30, 2026
    const notice = document.getElementById('launch-notice');
    const hideAfter = new Date('2026-07-01T00:00:00Z');
    if (notice && new Date() < hideAfter) {
      notice.classList.remove('hidden');
    }
  </script>

  <!-- ════════════════════════════════════════════════════════════
       APPLICATIONS (Open, Free, Research-first)
       ════════════════════════════════════════════════════════════ -->
  <section class="py-24 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold text-oasis-500 uppercase tracking-wider mb-2">Applications</p>
        <h2 class="text-3xl md:text-4xl font-bold text-charcoal">Open. Free. Built for Research.</h2>
        <p class="mt-4 text-slate-custom max-w-2xl mx-auto">
          An open-source platform purpose-built for qualitative data collection, from in-depth interviews to structured survey protocols.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 rounded-2xl bg-oasis-50 text-oasis-500 flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
            </svg>
          </div>
          <h3 class="font-semibold text-charcoal mb-2">Qualitative Surveys</h3>
          <p class="text-sm text-slate-custom leading-relaxed">
            Conduct in-depth interviews at scale. Define your protocol, let the agent probe, and get publication-ready transcripts.
          </p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 rounded-2xl bg-oasis-50 text-oasis-500 flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
            </svg>
          </div>
          <h3 class="font-semibold text-charcoal mb-2">Semi-Structured &amp; Open Interviews</h3>
          <p class="text-sm text-slate-custom leading-relaxed">
            Preset questions with adaptive follow-up probing, or fully open-ended conversations. You set the structure, the agent stays on track.
          </p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 rounded-2xl bg-oasis-50 text-oasis-500 flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <h3 class="font-semibold text-charcoal mb-2">Data Collection at Scale</h3>
          <p class="text-sm text-slate-custom leading-relaxed">
            Whether it's 10 or 10,000 interviews, manage studies, track participants with identifiers, and export structured data for analysis.
          </p>
        </div>
      </div>
    </div>
  </section>


  <!-- ════════════════════════════════════════════════════════════
       DEMO: Video Carousel
       ════════════════════════════════════════════════════════════ -->
  <section class="py-20 bg-off-white">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <p class="text-sm font-semibold text-oasis-500 uppercase tracking-wider mb-2">Preview</p>
      <h2 class="text-3xl md:text-4xl font-bold text-charcoal mb-4">See It in Action</h2>
      <p class="text-slate-custom max-w-xl mx-auto mb-10 text-sm">
        Three steps from setup to insights. Click through the walkthrough below.
      </p>

      <!-- Carousel -->
      <div class="relative" id="demo-carousel">
        <!-- Tabs -->
        <div class="flex items-center justify-center gap-2 mb-6">
          <button data-slide="0" class="carousel-tab active text-sm font-semibold px-4 py-2 rounded-lg transition-all bg-oasis-500 text-white shadow-md">
            1 · Setup Study
          </button>
          <button data-slide="1" class="carousel-tab text-sm font-semibold px-4 py-2 rounded-lg transition-all bg-oasis-50 text-oasis-600 hover:bg-oasis-100">
            2 · Configure Agent
          </button>
          <button data-slide="2" class="carousel-tab text-sm font-semibold px-4 py-2 rounded-lg transition-all bg-oasis-50 text-oasis-600 hover:bg-oasis-100">
            3 · Collect Data
          </button>
        </div>

        <!-- Slides -->
        <div class="relative overflow-hidden rounded-2xl border-2 border-oasis-100 bg-charcoal">
          <!-- Slide 0 -->
          <div class="carousel-slide transition-opacity duration-500" data-index="0">
            <video
              class="w-full aspect-video object-cover"
              src="/demo1-fast.mp4"
              muted
              playsinline
              autoplay
            ></video>
          </div>

          <!-- Slide 1 -->
          <div class="carousel-slide transition-opacity duration-500 hidden" data-index="1">
            <video
              class="w-full aspect-video object-cover"
              src="/demo2-fast.mp4"
              muted
              playsinline
            ></video>
          </div>

          <!-- Slide 2 -->
          <div class="carousel-slide transition-opacity duration-500 hidden" data-index="2">
            <video
              class="w-full aspect-video object-cover"
              src="/demo3-fast.mp4"
              muted
              playsinline
            ></video>
          </div>
        </div>

        <!-- Navigation arrows -->
        <div class="flex items-center justify-center gap-4 mt-6">
          <button id="carousel-prev" class="w-10 h-10 rounded-full bg-oasis-50 text-oasis-500 hover:bg-oasis-100 flex items-center justify-center transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
            </svg>
          </button>
          <div class="flex items-center gap-2" id="carousel-dots">
            <span class="w-2.5 h-2.5 rounded-full bg-oasis-500 transition-colors"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-oasis-200 transition-colors"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-oasis-200 transition-colors"></span>
          </div>
          <button id="carousel-next" class="w-10 h-10 rounded-full bg-oasis-50 text-oasis-500 hover:bg-oasis-100 flex items-center justify-center transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </section>

  <script>
    // Carousel logic with video auto-advance
    const slides = document.querySelectorAll('.carousel-slide');
    const tabs = document.querySelectorAll('.carousel-tab');
    const dots = document.querySelectorAll('#carousel-dots span');
    const prevBtn = document.getElementById('carousel-prev');
    const nextBtn = document.getElementById('carousel-next');
    let current = 0;

    function goTo(idx: number) {
      if (idx < 0) idx = slides.length - 1;
      if (idx >= slides.length) idx = 0;

      slides.forEach((s, i) => {
        const el = s as HTMLElement;
        const video = el.querySelector('video');
        if (i === idx) {
          el.classList.remove('hidden');
          if (video) {
            video.currentTime = 0;
            video.play().catch(() => {});
          }
        } else {
          el.classList.add('hidden');
          if (video) {
            video.pause();
          }
        }
      });

      tabs.forEach((t, i) => {
        if (i === idx) {
          t.classList.remove('bg-oasis-50', 'text-oasis-600', 'hover:bg-oasis-100');
          t.classList.add('bg-oasis-500', 'text-white', 'shadow-md');
        } else {
          t.classList.remove('bg-oasis-500', 'text-white', 'shadow-md');
          t.classList.add('bg-oasis-50', 'text-oasis-600', 'hover:bg-oasis-100');
        }
      });

      dots.forEach((d, i) => {
        d.classList.toggle('bg-oasis-500', i === idx);
        d.classList.toggle('bg-oasis-200', i !== idx);
      });

      current = idx;
    }

    // Auto-advance when a video ends
    slides.forEach((s, i) => {
      const video = s.querySelector('video');
      if (video) {
        video.addEventListener('ended', () => {
          // Advance to next slide (wraps from 3rd back to 1st)
          goTo(i + 1);
        });
      }
    });

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const slideIdx = parseInt(tab.getAttribute('data-slide') || '0');
        goTo(slideIdx);
      });
    });
    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));
  </script>


  <!-- ════════════════════════════════════════════════════════════
       FEATURES
       ════════════════════════════════════════════════════════════ -->
  <section id="features" class="py-24 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold text-oasis-500 uppercase tracking-wider mb-2">Capabilities</p>
        <h2 class="text-3xl md:text-4xl font-bold text-charcoal">Everything You Need for AI Interviews</h2>
        <p class="mt-4 text-slate-custom max-w-2xl mx-auto">
          Voice conversations, text chat, structured protocols, all in one self-hosted platform with full model flexibility.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger">
        <!-- Feature 1 -->
        <div class="group bg-white rounded-2xl p-6 border border-oasis-100/60 hover:border-oasis-300/60 transition-all hover:shadow-lg hover:shadow-oasis-100/50 animate-fade-in-up">
          <div class="w-12 h-12 rounded-xl bg-oasis-100 text-oasis-500 flex items-center justify-center mb-4 group-hover:bg-oasis-500 group-hover:text-white transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" />
            </svg>
          </div>
          <h3 class="font-semibold text-charcoal text-lg mb-2">Voice Agents</h3>
          <p class="text-sm text-slate-custom leading-relaxed">
            Real-time voice-to-voice interviews using OpenAI Realtime, Gemini Live, or modular STT→LLM→TTS pipelines with Deepgram + ElevenLabs.
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="group bg-white rounded-2xl p-6 border border-oasis-100/60 hover:border-oasis-300/60 transition-all hover:shadow-lg hover:shadow-oasis-100/50 animate-fade-in-up">
          <div class="w-12 h-12 rounded-xl bg-oasis-100 text-oasis-500 flex items-center justify-center mb-4 group-hover:bg-oasis-500 group-hover:text-white transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />
            </svg>
          </div>
          <h3 class="font-semibold text-charcoal text-lg mb-2">Text Chat Agents</h3>
          <p class="text-sm text-slate-custom leading-relaxed">
            Clean chat interface for text-based interviews. Customisable avatars, same structured data output, no audio required.
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="group bg-white rounded-2xl p-6 border border-oasis-100/60 hover:border-oasis-300/60 transition-all hover:shadow-lg hover:shadow-oasis-100/50 animate-fade-in-up">
          <div class="w-12 h-12 rounded-xl bg-oasis-100 text-oasis-500 flex items-center justify-center mb-4 group-hover:bg-oasis-500 group-hover:text-white transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
            </svg>
          </div>
          <h3 class="font-semibold text-charcoal text-lg mb-2">Structured Protocols</h3>
          <p class="text-sm text-slate-custom leading-relaxed">
            Semi-structured interview guides with preset questions, follow-up probes, and configurable transitions. Upload protocols via CSV or JSON.
          </p>
        </div>

        <!-- Feature 4 -->
        <div class="group bg-white rounded-2xl p-6 border border-oasis-100/60 hover:border-oasis-300/60 transition-all hover:shadow-lg hover:shadow-oasis-100/50 animate-fade-in-up">
          <div class="w-12 h-12 rounded-xl bg-sand-300 text-sand-700 flex items-center justify-center mb-4 group-hover:bg-sand-500 group-hover:text-white transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z" />
            </svg>
