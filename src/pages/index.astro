          <h3 class="font-semibold text-charcoal mb-2">Data Collection at Scale</h3>
          <p class="text-sm text-slate-custom leading-relaxed">
            Whether it's 10 or 10,000 interviews, manage studies, track participants with identifiers, and export structured data for analysis.
          </p>
        </div>
      </div>
    </div>
  </section>


  <!-- ════════════════════════════════════════════════════════════
       DEMO: Video Carousel
       ════════════════════════════════════════════════════════════ -->
  <section class="py-20 bg-off-white">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <p class="text-sm font-semibold text-oasis-500 uppercase tracking-wider mb-2">Preview</p>
      <h2 class="text-3xl md:text-4xl font-bold text-charcoal mb-4">See It in Action</h2>
      <p class="text-slate-custom max-w-xl mx-auto mb-10 text-sm">
        Three steps from setup to insights. Click through the walkthrough below.
      </p>

      <!-- Carousel -->
      <div class="relative" id="demo-carousel">
        <!-- Tabs -->
        <div class="flex items-center justify-center gap-2 mb-6">
          <button data-slide="0" class="carousel-tab active text-sm font-semibold px-4 py-2 rounded-lg transition-all bg-oasis-500 text-white shadow-md">
            1 · Setup Study
          </button>
          <button data-slide="1" class="carousel-tab text-sm font-semibold px-4 py-2 rounded-lg transition-all bg-oasis-50 text-oasis-600 hover:bg-oasis-100">
            2 · Configure Agent
          </button>
          <button data-slide="2" class="carousel-tab text-sm font-semibold px-4 py-2 rounded-lg transition-all bg-oasis-50 text-oasis-600 hover:bg-oasis-100">
            3 · Collect Data
          </button>
        </div>

        <!-- Slides -->
        <div class="relative overflow-hidden rounded-2xl border-2 border-oasis-100 bg-charcoal">
          <!-- Slide 0 -->
          <div class="carousel-slide transition-opacity duration-500" data-index="0">
            <video
              class="w-full aspect-video object-cover"
              src="/demo1-fast.mp4"
              muted
              playsinline
              autoplay
            ></video>
          </div>

          <!-- Slide 1 -->
          <div class="carousel-slide transition-opacity duration-500 hidden" data-index="1">
            <video
              class="w-full aspect-video object-cover"
              src="/demo2-fast.mp4"
              muted
              playsinline
            ></video>
          </div>

          <!-- Slide 2 -->
          <div class="carousel-slide transition-opacity duration-500 hidden" data-index="2">
            <video
              class="w-full aspect-video object-cover"
              src="/demo3-fast.mp4"
              muted
              playsinline
            ></video>
          </div>
        </div>

        <!-- Navigation arrows -->
        <div class="flex items-center justify-center gap-4 mt-6">
          <button id="carousel-prev" class="w-10 h-10 rounded-full bg-oasis-50 text-oasis-500 hover:bg-oasis-100 flex items-center justify-center transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
            </svg>
          </button>
          <div class="flex items-center gap-2" id="carousel-dots">
            <span class="w-2.5 h-2.5 rounded-full bg-oasis-500 transition-colors"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-oasis-200 transition-colors"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-oasis-200 transition-colors"></span>
          </div>
          <button id="carousel-next" class="w-10 h-10 rounded-full bg-oasis-50 text-oasis-500 hover:bg-oasis-100 flex items-center justify-center transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </section>

  <script>
    // Carousel logic with video auto-advance
    const slides = document.querySelectorAll('.carousel-slide');
    const tabs = document.querySelectorAll('.carousel-tab');
    const dots = document.querySelectorAll('#carousel-dots span');
    const prevBtn = document.getElementById('carousel-prev');
    const nextBtn = document.getElementById('carousel-next');
    let current = 0;

    function goTo(idx: number) {
      if (idx < 0) idx = slides.length - 1;
      if (idx >= slides.length) idx = 0;

      slides.forEach((s, i) => {
        const el = s as HTMLElement;
        const video = el.querySelector('video');
        if (i === idx) {
          el.classList.remove('hidden');
          if (video) {
            video.currentTime = 0;
            video.play().catch(() => {});
          }
        } else {
          el.classList.add('hidden');
          if (video) {
            video.pause();
          }
        }
      });

      tabs.forEach((t, i) => {
        if (i === idx) {
          t.classList.remove('bg-oasis-50', 'text-oasis-600', 'hover:bg-oasis-100');
          t.classList.add('bg-oasis-500', 'text-white', 'shadow-md');
        } else {
          t.classList.remove('bg-oasis-500', 'text-white', 'shadow-md');
          t.classList.add('bg-oasis-50', 'text-oasis-600', 'hover:bg-oasis-100');
        }
      });

      dots.forEach((d, i) => {
        d.classList.toggle('bg-oasis-500', i === idx);
        d.classList.toggle('bg-oasis-200', i !== idx);
      });

      current = idx;
    }

    // Auto-advance when a video ends
    slides.forEach((s, i) => {
      const video = s.querySelector('video');
      if (video) {
        video.addEventListener('ended', () => {
          // Advance to next slide (wraps from 3rd back to 1st)
          goTo(i + 1);
        });
      }
    });

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const slideIdx = parseInt(tab.getAttribute('data-slide') || '0');
        goTo(slideIdx);
      });
    });
    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));
  </script>


  <!-- ════════════════════════════════════════════════════════════
       FEATURES
       ════════════════════════════════════════════════════════════ -->
  <section id="features" class="py-24 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold text-oasis-500 uppercase tracking-wider mb-2">Capabilities</p>
        <h2 class="text-3xl md:text-4xl font-bold text-charcoal">Everything You Need for AI Interviews</h2>
        <p class="mt-4 text-slate-custom max-w-2xl mx-auto">
          Voice conversations, text chat, structured protocols, all in one self-hosted platform with full model flexibility.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger">
        <!-- Feature 1 -->
