       ════════════════════════════════════════════════════════════ -->
  <section id="how-it-works" class="py-24 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold text-oasis-500 uppercase tracking-wider mb-2">Setup</p>
        <h2 class="text-3xl md:text-4xl font-bold text-charcoal">Three Steps to Your First Interview</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Step 1 -->
        <div class="relative text-center">
          <div class="w-14 h-14 rounded-full bg-oasis-500 text-white flex items-center justify-center mx-auto mb-5 text-xl font-bold shadow-lg shadow-oasis-500/20">1</div>
          <h3 class="font-semibold text-charcoal text-lg mb-2">Clone &amp; Configure</h3>
          <p class="text-sm text-slate-custom leading-relaxed">
            Clone the repository, copy <code>.env.example</code> to <code>.env</code>, and add your API keys. That's your entire infrastructure config.
          </p>
          <div class="mt-4 bg-charcoal rounded-xl p-4 text-left">
            <code class="text-sm text-oasis-300 font-mono">
              <span class="text-white/40">$</span> git clone https://github.com/oasis-surveys/oasis-platform.git<br/>
              <span class="text-white/40">$</span> cp .env.example .env<br/>
              <span class="text-white/40">$</span> nano .env
            </code>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="relative text-center">
          <div class="w-14 h-14 rounded-full bg-oasis-500 text-white flex items-center justify-center mx-auto mb-5 text-xl font-bold shadow-lg shadow-oasis-500/20">2</div>
          <h3 class="font-semibold text-charcoal text-lg mb-2">Deploy</h3>
          <p class="text-sm text-slate-custom leading-relaxed">
            One command spins up five containers: reverse proxy, frontend dashboard, backend API, PostgreSQL, and Redis.
          </p>
          <div class="mt-4 bg-charcoal rounded-xl p-4 text-left">
            <code class="text-sm text-oasis-300 font-mono">
              <span class="text-white/40">$</span> docker compose up -d
            </code>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="relative text-center">
          <div class="w-14 h-14 rounded-full bg-oasis-500 text-white flex items-center justify-center mx-auto mb-5 text-xl font-bold shadow-lg shadow-oasis-500/20">3</div>
          <h3 class="font-semibold text-charcoal text-lg mb-2">Create &amp; Share</h3>
          <p class="text-sm text-slate-custom leading-relaxed">
            Open the dashboard, define your agent's prompt and model, and share the interview link (or embed it in Qualtrics).
          </p>
          <div class="mt-4 bg-charcoal rounded-xl p-4 text-left">
            <code class="text-sm text-sand-400 font-mono">
              → Dashboard live at localhost:80<br/>
              → Interview link ready to share
            </code>
          </div>
        </div>
      </div>
    </div>
  </section>



  <!-- ════════════════════════════════════════════════════════════
       A NOTE ON SCOPE
       ════════════════════════════════════════════════════════════ -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <p class="text-slate-custom leading-relaxed text-sm md:text-base italic">
        OASIS is not trying to compete with enterprise platforms that have full-time engineering teams and
        millions in funding. It does not need to. What matters is that researchers have access to open, transparent
        tools they can run themselves, inspect, and adapt. If it helps one research group collect better data
        without a vendor contract, it has done its job.
      </p>
    </div>
  </section>


