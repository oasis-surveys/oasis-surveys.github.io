---
import Base from '../layouts/Base.astro';
---

<Base
  title="Imprint | OASIS"
  description="Legal information and contact details for the OASIS project."
  activeNav=""
>

  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-oasis-50 via-off-white to-sand-100 -z-10"></div>
    <div class="max-w-4xl mx-auto px-6 py-24 md:py-28">
      <p class="text-sm font-semibold text-oasis-500 uppercase tracking-wider mb-3 animate-fade-in">Legal</p>
      <h1 class="text-4xl md:text-5xl font-extrabold text-charcoal leading-tight animate-fade-in-up">
        Imprint
      </h1>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6">

      <div class="space-y-10">

        <!-- Contact Information -->
        <div>
          <h2 class="text-xl font-bold text-charcoal mb-4">Contact</h2>
          <div class="bg-off-white rounded-xl border border-oasis-100/40 p-6 text-sm text-slate-custom leading-relaxed space-y-1">
            <p class="font-semibold text-charcoal text-base">Max Melchior Lang</p>
            <p>Big Data Institute</p>
            <p>Old Road Campus</p>
            <p>University of Oxford</p>
            <p>Oxford OX3 7LF</p>
            <p>United Kingdom</p>
            <p class="mt-3">
              <strong class="text-charcoal">Email:</strong>
              <a href="mailto:max.lang@stx.ox.ac.uk" class="text-oasis-500 hover:underline">max.lang@stx.ox.ac.uk</a>
            </p>
          </div>
        </div>

        <!-- Responsible for Content -->
        <div>
          <h2 class="text-xl font-bold text-charcoal mb-4">Responsible for Content</h2>
          <p class="text-sm text-slate-custom leading-relaxed">
            Max Melchior Lang<br />
            Address as stated above.
          </p>
        </div>

        <!-- Disclaimer -->
        <div>
          <h2 class="text-xl font-bold text-charcoal mb-4">Disclaimer</h2>

          <div class="space-y-4 text-sm text-slate-custom leading-relaxed">
            <div>
              <h3 class="font-semibold text-charcoal mb-1">Liability for Content</h3>
              <p>
                The contents of this website have been created with the utmost care. However, I cannot guarantee the
                accuracy, completeness, or timeliness of the content. As a service provider, I am responsible for my own
                content on these pages in accordance with general laws. However, I am not obligated to monitor transmitted
                or stored third-party information or to investigate circumstances that indicate illegal activity.
              </p>
            </div>

            <div>
              <h3 class="font-semibold text-charcoal mb-1">Liability for Links</h3>
              <p>
                This website contains links to external third-party websites over whose content I have no influence.
                Therefore, I cannot accept any liability for these external contents. The respective provider or operator
                of the linked pages is always responsible for the contents of the linked pages. The linked pages were
                checked for possible legal violations at the time of linking. Illegal contents were not recognisable at
                the time of linking.
              </p>
            </div>

            <div>
              <h3 class="font-semibold text-charcoal mb-1">Copyright &amp; License</h3>
              <p>
                The content of this website is &copy; {new Date().getFullYear()} Max M. Lang. The OASIS software is
                licensed under the
                <a href="https://www.gnu.org/licenses/agpl-3.0.html" target="_blank" rel="noopener noreferrer" class="text-oasis-500 hover:underline">GNU Affero General Public License v3.0 (AGPL-3.0)</a>.
                Academic and research use — including within funded projects — is fully permitted. The AGPL's
                network-service clause ensures that derivative works offered as online services remain open-source.
                For a plain-English summary, see the
                <a href="https://github.com/oasis-surveys/oasis-platform/blob/main/FAQ.md#whats-the-deal-with-the-license" target="_blank" rel="noopener noreferrer" class="text-oasis-500 hover:underline">licensing FAQ</a>.
              </p>
            </div>

            <div>
              <h3 class="font-semibold text-charcoal mb-1">Data Protection</h3>
              <p>
                This website is hosted on GitHub Pages. For information about data processing by GitHub, please refer to
                <a href="https://docs.github.com/en/site-policy/privacy-policies/github-general-privacy-statement" target="_blank" rel="noopener noreferrer" class="text-oasis-500 hover:underline">GitHub's Privacy Statement</a>.
                This website does not use cookies or analytics tools. No personal data is collected, stored, or processed
                by the website operator.
              </p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

</Base>
