  <!-- Scroll-spy script for sidebar nav -->
  <script>
    const sections = ['story', 'principles', 'team', 'research', 'vision', 'contact'];
    const navLinks = document.querySelectorAll('.about-nav-link');

    function updateActiveNav() {
      const scrollY = window.scrollY + 200;
      let currentSection = sections[0];

      for (const id of sections) {
        const el = document.getElementById(id);
        if (el && el.offsetTop <= scrollY) {
          currentSection = id;
        }
      }

      navLinks.forEach(link => {
        const section = link.getAttribute('data-section');
        const dot = link.querySelector('.about-nav-dot') as HTMLElement;
        if (section === currentSection) {
          link.classList.remove('text-slate-custom/60');
          link.classList.add('text-oasis-500', 'font-semibold', 'bg-oasis-50/60');
          if (dot) {
            dot.classList.remove('bg-slate-custom/20', 'w-1.5', 'h-1.5');
            dot.classList.add('bg-oasis-500', 'w-2', 'h-2');
          }
        } else {
          link.classList.remove('text-oasis-500', 'font-semibold', 'bg-oasis-50/60');
          link.classList.add('text-slate-custom/60');
          if (dot) {
            dot.classList.remove('bg-oasis-500', 'w-2', 'h-2');
            dot.classList.add('bg-slate-custom/20', 'w-1.5', 'h-1.5');
          }
        }
      });
    }

    window.addEventListener('scroll', updateActiveNav, { passive: true });
    updateActiveNav();
  </script>

