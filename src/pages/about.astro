              </a>
              <a href="https://maxmlang.github.io" target="_blank" rel="noopener noreferrer" class="text-slate-custom hover:text-oasis-500 transition-colors" aria-label="Website">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" /></svg>
              </a>
              <a href="https://scholar.google.com/citations?user=MaxMLang" target="_blank" rel="noopener noreferrer" class="text-slate-custom hover:text-oasis-500 transition-colors" aria-label="Google Scholar">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 100 14 7 7 0 000-14z"/></svg>
              </a>
              <a href="mailto:max.lang@stx.ox.ac.uk" class="text-slate-custom hover:text-oasis-500 transition-colors" aria-label="Email">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Join the Team -->
      <div class="max-w-2xl mx-auto mt-10 text-center">
        <h3 class="text-xl font-bold text-charcoal mb-3">Join the Team</h3>
        <p class="text-sm text-slate-custom mb-6">Interested in contributing or collaborating? Get involved.</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="https://github.com/oasis-surveys/oasis-platform"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-charcoal hover:bg-charcoal/90 text-white font-semibold px-7 py-3.5 rounded-xl transition-all hover:-translate-y-0.5"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
