---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  activeNav?: string;
}

const {
  title = 'OASIS | Open Agentic Survey Interview System',
  description = 'Self-hosted, open-source platform for AI-powered conversational interviews. Voice agents, text chat, structured protocols. Full control over your research infrastructure.',
  activeNav = 'home',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Max M. Lang" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/oasis-logo.png" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/oasis-logo.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>

  <body class="min-h-screen flex flex-col">
    <!-- ── Nav ──────────────────────────────────────────────── -->
    <nav class="fixed top-0 inset-x-0 z-50 bg-off-white/80 backdrop-blur-lg border-b border-oasis-100/60">
      <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2.5 group">
          <img src="/oasis-logo.png" alt="OASIS" class="h-9 w-9 transition-transform group-hover:scale-105" />
          <span class="font-bold text-lg tracking-tight text-charcoal">OASIS</span>
        </a>

        <!-- Links -->
        <div class="hidden sm:flex items-center gap-8 text-sm font-medium">
          <a
            href="/"
            class:list={[
              'transition-colors hover:text-oasis-500',
              activeNav === 'home' ? 'text-oasis-500' : 'text-slate-custom',
            ]}
          >Home</a>
          <a
            href="/docs"
            class:list={[
              'transition-colors hover:text-oasis-500',
              activeNav === 'docs' ? 'text-oasis-500' : 'text-slate-custom',
            ]}
          >Docs</a>
          <a
            href="/about"
            class:list={[
              'transition-colors hover:text-oasis-500',
              activeNav === 'about' ? 'text-oasis-500' : 'text-slate-custom',
            ]}
          >About</a>
          <a
            href="https://github.com/oasis-surveys"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-slate-custom hover:text-oasis-500 transition-colors"
          >
            GitHub
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" />
            </svg>
          </a>
        </div>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="sm:hidden p-2 -mr-2 text-charcoal hover:text-oasis-500 transition-colors"
          aria-label="Toggle menu"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>

      <!-- Mobile dropdown -->
      <div id="mobile-menu" class="hidden sm:hidden border-t border-oasis-100/60 bg-off-white/95 backdrop-blur-lg">
        <div class="px-6 py-4 space-y-3 text-sm font-medium">
          <a href="/" class="block text-slate-custom hover:text-oasis-500 transition-colors">Home</a>
          <a href="/docs" class="block text-slate-custom hover:text-oasis-500 transition-colors">Docs</a>
          <a href="/about" class="block text-slate-custom hover:text-oasis-500 transition-colors">About</a>
          <a href="https://github.com/oasis-surveys" target="_blank" rel="noopener noreferrer" class="block text-slate-custom hover:text-oasis-500 transition-colors">GitHub ↗</a>
        </div>
      </div>
    </nav>

    <!-- ── Main Content ─────────────────────────────────────── -->
    <main class="flex-1 pt-16">
      <slot />
    </main>

    <!-- ── Footer ───────────────────────────────────────────── -->
    <footer class="border-t border-oasis-100/60 bg-charcoal text-white/70">
      <div class="max-w-6xl mx-auto px-6 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Brand -->
          <div>
            <div class="flex items-center gap-2.5 mb-3">
              <img src="/oasis-logo.png" alt="OASIS" class="h-8 w-8" />
              <span class="font-bold text-white text-lg tracking-tight">OASIS</span>
            </div>
            <p class="text-sm leading-relaxed">
              Open Agentic Survey Interview System.<br/>
              Self-hosted AI interview infrastructure for researchers.
            </p>
          </div>

          <!-- Links -->
          <div>
            <h4 class="font-semibold text-white text-sm mb-3 uppercase tracking-wider">Navigate</h4>
            <ul class="space-y-2 text-sm">
              <li><a href="/" class="hover:text-oasis-300 transition-colors">Home</a></li>
              <li><a href="/docs" class="hover:text-oasis-300 transition-colors">Documentation</a></li>
              <li><a href="/about" class="hover:text-oasis-300 transition-colors">About</a></li>
              <li><a href="https://github.com/oasis-surveys/oasis-platform" target="_blank" rel="noopener noreferrer" class="hover:text-oasis-300 transition-colors">GitHub ↗</a></li>
            </ul>
          </div>

          <!-- Contact -->
          <div>
            <h4 class="font-semibold text-white text-sm mb-3 uppercase tracking-wider">Get in Touch</h4>
            <p class="text-sm leading-relaxed mb-3">
              Interested in using OASIS for your research?<br/>
              Want to collaborate or contribute?
            </p>
            <a
              href="mailto:max.lang@stx.ox.ac.uk"
              class="inline-flex items-center gap-1.5 text-oasis-300 hover:text-oasis-200 transition-colors text-sm font-medium"
            >
              max.lang@stx.ox.ac.uk
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </a>
          </div>
        </div>

        <div class="mt-10 pt-6 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-white/40">
          <p>&copy; {new Date().getFullYear()} OASIS Project</p>
          <div class="flex items-center gap-4">
            <a href="/imprint" class="underline hover:text-white/60 transition-colors">Imprint</a>
            <span>·</span>
            <a href="/license" class="underline hover:text-white/60 transition-colors">License</a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Mobile menu toggle -->
    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
    </script>
  </body>
</html>
